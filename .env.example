# Пример .env файла
# Скопируйте этот файл в .env и заполните значения

# ============================================
# TELEGRAM BOT SETTINGS
# ============================================
# Получите токен у @BotFather в Telegram
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ID администраторов через запятую
# Узнать свой ID: @userinfobot
ADMIN_IDS=123456789,987654321

# ============================================
# MARZNESHIN API SETTINGS
# ============================================
# URL вашей панели Marzneshin
MARZNESHIN_API_URL=http://your_marzneshin_domain:8000

# Учетные данные администратора Marzneshin
MARZNESHIN_ADMIN_USERNAME=admin
MARZNESHIN_ADMIN_PASSWORD=admin_password

# Опционально: заранее полученный API токен (ускоряет работу)
# Если пусто - получит автоматически через username/password
# Получить токен: curl -X POST "http://your_domain:8000/api/admins/token" \
#   -H "Content-Type: application/x-www-form-urlencoded" \
#   -d "username=admin&password=password"
MARZNESHIN_ACCESS_TOKEN=

# ============================================
# SERVICE CONFIGURATION
# ============================================
# ID сервиса в Marzneshin
SERVICE_ID=1

# ID inbound в Marzneshin
INBOUND_ID=1

# ============================================
# DATABASE SETTINGS
# ============================================
# Для SQLite:
DATABASE_URL=sqlite:///./bot.db

# Для PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/dbname

# Для MySQL:
# DATABASE_URL=mysql+aiomysql://user:password@localhost/dbname

# ============================================
# PRICING
# ============================================
# Цены в рублях
PRICE_1_MONTH=99
PRICE_3_MONTHS=279
PRICE_6_MONTHS=579
PRICE_12_MONTHS=999

# ============================================
# TRIAL SETTINGS
# ============================================
# Количество дней пробного периода
TRIAL_DAYS=3

# ============================================
# PAYMENT SETTINGS
# ============================================
# SBP merchant ID (когда будет реальная интеграция)
SBP_MERCHANT_ID=your_sbp_merchant

# Включить платежи банковскими картами
BANK_CARD_ENABLED=true

# Включить Telegram Stars
TELEGRAM_STARS_ENABLED=false

# ============================================
# REFERRAL SYSTEM
# ============================================
# Баллы за каждого активного приглашенного пользователя
REFERRAL_BONUS_POINTS=10

# Соотношение баллов к рублям (1 балл = 1 рубль)
POINTS_TO_RUBLE_RATIO=1

# ============================================
# SUPPORT
# ============================================
# Ссылка на техподдержку
SUPPORT_CHAT_URL=t.me/vpnsakura

# ============================================
# LOGGING
# ============================================
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
